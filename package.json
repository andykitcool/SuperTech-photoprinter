{
  "name": "supertech-photoprinter",
  "version": "0.1.0",
  "private": true,
  "description": "Local Windows photo print client for supertech-program-manager.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "start": "node scripts/start-electron.cjs .",
    "preview": "vite preview --host 127.0.0.1",
    "pack": "electron-builder --win --config"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^35.1.2",
    "fabric": "^6.6.1",
    "lucide-vue-next": "^0.468.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vue": "^3.5.13",
    "vue-tsc": "^2.2.8"
  },
  "devDependencies": {
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.supertech.photoprinter",
    "productName": "Supertech PhotoPrinter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    }
  }
}
